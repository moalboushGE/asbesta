{
  "extends": ["stylelint-config-standard"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "theme",
          "source",
          "utility",
          "variant",
          "custom-variant",
          "apply",
          "tailwind",
          "config",
          "plugin",
          "reference",
          "layer",
          "screen"
        ]
      }
    ],
    "import-notation": "string",
    "property-no-unknown": [true, { "ignoreProperties": ["animation-timeline", "animation-range"] }],
    "value-keyword-case": null,
    "custom-property-empty-line-before": null,
    "comment-empty-line-before": null
  }
}
