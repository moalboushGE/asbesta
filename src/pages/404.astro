---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import { site } from '../data/site';

const links = [
  { href: '/leistungen/', label: 'Alle Leistungen', icon: 'lucide:shield-check' },
  { href: '/standorte/', label: 'Standorte & Einsatzgebiet', icon: 'lucide:map-pin' },
  { href: '/ratgeber/', label: 'Ratgeber', icon: 'lucide:book-open' },
  { href: '/kontakt/', label: 'Kontakt & Anfrage', icon: 'lucide:clipboard-list' },
];
---

<BaseLayout
  title="Seite nicht gefunden (404) | Asbesta Schadstoffsanierung"
  description="Diese Seite existiert nicht oder wurde verschoben. Finden Sie hier zurück zu Leistungen, Standorten und Kontakt der Asbesta Schadstoffsanierung."
  noindex
>
  <section class="mx-auto max-w-3xl px-4 py-20 text-center lg:px-8 lg:py-28">
    <p class="font-display text-6xl font-semibold text-red-600 sm:text-7xl">404</p>
    <h1 class="mt-4 text-3xl sm:text-4xl">Diese Seite haben wir nicht gefunden</h1>
    <p class="mt-5 text-lg text-gray-700">
      Der Link ist veraltet oder die Adresse wurde falsch eingegeben. Kein Problem – über die
      folgenden Wege finden Sie schnell, was Sie suchen.
    </p>

    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <Button href={site.phone.href} variant="primary">
        <Icon name="lucide:phone" class="h-4 w-4" />Jetzt anrufen
      </Button>
      <Button href="/" variant="ghost">
        <Icon name="lucide:home" class="h-4 w-4" />Zur Startseite
      </Button>
    </div>

    <ul class="mx-auto mt-10 grid max-w-xl gap-3 sm:grid-cols-2">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              class="flex items-center justify-between gap-3 rounded-[var(--radius-card)] border border-gray-200 bg-white p-4 text-left transition-colors hover:border-red-600"
            >
              <span class="flex items-center gap-3">
                <Icon name={l.icon} class="h-5 w-5 shrink-0 text-red-600" />
                <span class="font-sans font-semibold text-ink-900">{l.label}</span>
              </span>
              <Icon name="lucide:arrow-right" class="h-4 w-4 shrink-0 text-red-600" />
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
