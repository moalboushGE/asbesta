---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaGraph from '../../components/schema/SchemaGraph.astro';
import Breadcrumb from '../../components/patterns/Breadcrumb.astro';
import Figure from '../../components/ui/Figure.astro';
import { ratgeberArtikel } from '../../data/ratgeber';
import { buildCollectionGraph } from '../../lib/schema';

const title = 'Ratgeber: Asbest & Schadstoffsanierung | Asbesta';
const description =
  'Fundierte Ratgeber rund um Asbest- und Schadstoffsanierung: Pflichten, Kosten, Ablauf und Praxiswissen vom zertifizierten Fachbetrieb aus NRW.';

const origin = Astro.site?.origin ?? 'https://www.asbesta-schadstoffsanierung.de';
const graph = buildCollectionGraph(origin, {
  name: 'Ratgeber',
  crumb: 'Ratgeber',
  description,
  path: '/ratgeber/',
  items: ratgeberArtikel.map((a) => ({ name: a.title, url: origin + '/ratgeber/' + a.slug + '/' })),
});

const fmt = (iso: string): string =>
  new Intl.DateTimeFormat('de-DE', { day: 'numeric', month: 'long', year: 'numeric' }).format(
    new Date(iso),
  );
---

<BaseLayout title={title} description={description}>
  <SchemaGraph slot="head" graph={graph} />

  <section class="border-b border-gray-200 bg-gradient-to-br from-red-50 via-white to-gray-50">
    <div class="mx-auto max-w-6xl px-4 py-12 lg:px-8 lg:py-16">
      <Breadcrumb items={[{ name: 'Start', href: '/' }, { name: 'Ratgeber' }]} />
      <p class="mt-6 text-sm font-semibold uppercase tracking-wider text-red-700">Ratgeber</p>
      <h1 class="mt-2 text-4xl sm:text-5xl">Ratgeber rund um Asbest &amp; Schadstoffe</h1>
      <p class="mt-5 max-w-2xl text-lg text-gray-700">
        Klar erklärt, fachlich fundiert und aus der Praxis: Pflichten, Kosten und Abläufe rund um die
        Asbest- und Schadstoffsanierung – damit Sie sicher entscheiden können.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12 lg:px-8 lg:py-16">
    <ul class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        ratgeberArtikel.map((a) => (
          <li>
            <a
              href={`/ratgeber/${a.slug}/`}
              class="group block overflow-hidden rounded-[var(--radius-card)] border border-gray-200 bg-white transition-all hover:-translate-y-1 hover:border-red-300 hover:shadow-xl"
            >
              <Figure
                src={a.heroImage}
                alt={a.heroAlt}
                aspect="16/9"
                rounded={false}
                sizes="(min-width: 1024px) 30vw, (min-width: 768px) 45vw, 100vw"
              />
              <div class="p-5">
                <span class="inline-flex items-center gap-1.5 rounded-full bg-red-50 px-3 py-1 text-xs font-semibold text-red-700">
                  <Icon name="lucide:book-open" class="h-3.5 w-3.5" />
                  {a.kategorie}
                </span>
                <h2 class="mt-3 font-sans text-lg font-semibold text-ink-900 group-hover:text-red-700">
                  {a.title}
                </h2>
                <p class="mt-2 text-sm leading-relaxed text-gray-700">{a.excerpt}</p>
                <p class="mt-4 flex items-center gap-x-2 text-xs text-gray-500">
                  <time datetime={a.datePublished}>{fmt(a.datePublished)}</time>
                  <span aria-hidden="true">·</span>
                  <span>{a.lesezeitMin} min Lesezeit</span>
                </p>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
