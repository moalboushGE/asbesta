---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import LeadListe from '../../components/admin/LeadListe.astro';
import { Icon } from 'astro-icon/components';
import { counts, listLeads, maybeRetentionSweep, type Counts, type Lead } from '../../lib/leads';

let stats: Counts | null = null;
let neueste: Lead[] = [];
let dbFehler = '';
try {
  maybeRetentionSweep().catch(() => undefined);
  stats = await counts();
  neueste = await listLeads({ limit: 8 });
} catch (e) {
  dbFehler = e instanceof Error ? e.message : 'Datenbank nicht erreichbar.';
}

const kacheln = stats
  ? [
      { label: 'Neu', wert: stats.neu, icon: 'lucide:sparkles', farbe: 'text-red-700', href: '/admin/anfragen/?status=neu' },
      { label: 'Offen', wert: stats.offen, icon: 'lucide:inbox', farbe: 'text-ink-900', href: '/admin/anfragen/?status=offen' },
      { label: 'Diese Woche', wert: stats.woche, icon: 'lucide:calendar-days', farbe: 'text-ink-900', href: '/admin/anfragen/' },
      { label: 'Gewonnen', wert: stats.gewonnen, icon: 'lucide:circle-check', farbe: 'text-success', href: '/admin/anfragen/?status=gewonnen' },
    ]
  : [];
---

<AdminLayout title="Übersicht" aktiv="uebersicht">
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <h1 class="text-2xl sm:text-3xl">Übersicht</h1>
      <p class="mt-1 text-sm text-gray-500">Eingegangene Anfragen verwalten und bearbeiten.</p>
    </div>
    <a
      href="/admin/anfragen/"
      class="inline-flex min-h-11 items-center gap-2 rounded-full bg-red-600 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-red-700"
    >
      <Icon name="lucide:inbox" class="h-4 w-4" />Alle Anfragen
    </a>
  </div>

  {
    dbFehler ? (
      <div class="mt-8 rounded-[var(--radius-card)] border border-gray-200 bg-white p-6 shadow-soft">
        <p class="flex items-center gap-2 font-sans font-semibold text-ink-900">
          <Icon name="lucide:database" class="h-5 w-5 text-red-600" />
          Datenbank noch nicht verbunden
        </p>
        <p class="mt-2 text-sm text-gray-600">
          Es konnte keine Verbindung zur Anfragen-Datenbank hergestellt werden. Bitte in Railway einen
          PostgreSQL-Dienst anlegen und die Variable <code class="rounded bg-gray-100 px-1">DATABASE_URL</code> mit dem
          Web-Service verknüpfen.
        </p>
        <p class="mt-2 text-xs text-gray-400">Technische Meldung: {dbFehler}</p>
      </div>
    ) : (
      <>
        <div class="mt-8 grid grid-cols-2 gap-4 lg:grid-cols-4">
          {kacheln.map((k) => (
            <a
              href={k.href}
              class="rounded-[var(--radius-card)] border border-gray-200 bg-white p-5 shadow-soft transition-transform hover:-translate-y-0.5"
            >
              <Icon name={k.icon} class:list={['h-5 w-5', k.farbe]} />
              <p class:list={['mt-3 font-display text-3xl font-extrabold', k.farbe]}>{k.wert}</p>
              <p class="mt-0.5 text-sm text-gray-500">{k.label}</p>
            </a>
          ))}
        </div>

        <h2 class="mt-10 text-lg">Neueste Anfragen</h2>
        <div class="mt-4">
          <LeadListe leads={neueste} leer="Noch keine Anfragen eingegangen." />
        </div>
      </>
    )
  }
</AdminLayout>
