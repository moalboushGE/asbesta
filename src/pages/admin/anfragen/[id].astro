---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import StatusBadge from '../../../components/admin/StatusBadge.astro';
import { Icon } from 'astro-icon/components';
import { getLead, STATUS, type Lead } from '../../../lib/leads';
import { statusMeta, formatDatum, telHref, waHref } from '../../../lib/admin-format';

const { id = '' } = Astro.params;
let lead: Lead | null = null;
let dbFehler = '';
try {
  lead = await getLead(id);
} catch (e) {
  dbFehler = e instanceof Error ? e.message : 'Datenbank nicht erreichbar.';
}
if (!dbFehler && !lead) Astro.response.status = 404;

const statusListe = STATUS.map((s) => ({ v: s, l: statusMeta(s).label }));

let mailText = '';
if (lead) {
  if (lead.mail_versendet) {
    mailText = 'Benachrichtigungs-Mail versendet.';
  } else {
    const grund = lead.mail_fehler ? ` (${lead.mail_fehler})` : '';
    mailText = `Keine Mail versendet${grund}.`;
  }
}
const kontakt = lead
  ? [
      { icon: 'lucide:phone', label: 'Telefon', wert: lead.telefon, href: telHref(lead.telefon) },
      { icon: 'lucide:mail', label: 'E-Mail', wert: lead.email, href: lead.email ? `mailto:${lead.email}` : '' },
      { icon: 'lucide:map-pin', label: 'Ort', wert: lead.ort, href: '' },
      { icon: 'lucide:wrench', label: 'Leistung', wert: lead.dienstleistung, href: '' },
      { icon: 'lucide:clock', label: 'Wunschzeit', wert: lead.wunschzeit, href: '' },
    ].filter((k) => k.wert)
  : [];
const quelle = lead
  ? [
      ['Kanal', lead.quelle_kanal],
      ['Kampagne', lead.utm_campaign],
      ['utm_source', lead.utm_source],
      ['utm_medium', lead.utm_medium],
      ['Landingpage', lead.landingpage],
      ['Referrer', lead.referrer],
    ].filter(([, v]) => v)
  : [];
---

<AdminLayout title={lead ? lead.name || 'Anfrage' : 'Anfrage'} aktiv="anfragen">
  <a href="/admin/anfragen/" class="inline-flex items-center gap-1.5 text-sm font-semibold text-red-700 hover:underline">
    <Icon name="lucide:arrow-left" class="h-4 w-4" />Zurück zur Liste
  </a>

  {
    !lead ? (
      <p class="mt-6 rounded-[var(--radius-card)] border border-gray-200 bg-white px-4 py-10 text-center text-sm text-gray-500">
        {dbFehler ? `Datenbank nicht erreichbar (${dbFehler}).` : 'Diese Anfrage existiert nicht (mehr).'}
      </p>
    ) : (
      <div class="mt-4 grid gap-6 lg:grid-cols-[1fr_20rem]">
        <div class="space-y-6">
          <div class="rounded-[var(--radius-card)] border border-gray-200 bg-white p-6 shadow-soft">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <h1 class="text-2xl">{lead.name || '(ohne Namen)'}</h1>
              <StatusBadge status={lead.status} />
            </div>
            <p class="mt-1 text-sm text-gray-500">
              {lead.typ === 'rueckruf' ? 'Rückruf-Wunsch' : 'Anfrage'} · eingegangen {formatDatum(lead.created_at)}
            </p>
            {lead.ist_spam && (
              <p class="mt-3 inline-flex items-center gap-1.5 rounded-lg bg-gray-100 px-3 py-1.5 text-xs text-gray-500">
                <Icon name="lucide:ban" class="h-3.5 w-3.5" />
                Automatisch als Spam erkannt ({lead.spam_grund ?? 'unbekannt'}) – keine E-Mail versendet.
              </p>
            )}

            <div class="mt-5 flex flex-wrap gap-2">
              {lead.telefon && (
                <a
                  href={telHref(lead.telefon)}
                  class="inline-flex min-h-11 items-center gap-2 rounded-full bg-red-600 px-5 text-sm font-semibold text-white hover:bg-red-700"
                >
                  <Icon name="lucide:phone" class="h-4 w-4" />Anrufen
                </a>
              )}
              {lead.telefon && (
                <a
                  href={waHref(lead.telefon)}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex min-h-11 items-center gap-2 rounded-full border border-gray-200 px-5 text-sm font-semibold text-ink-900 hover:border-red-600 hover:text-red-700"
                >
                  <Icon name="lucide:message-circle" class="h-4 w-4" />WhatsApp
                </a>
              )}
              {lead.email && (
                <a
                  href={`mailto:${lead.email}`}
                  class="inline-flex min-h-11 items-center gap-2 rounded-full border border-gray-200 px-5 text-sm font-semibold text-ink-900 hover:border-red-600 hover:text-red-700"
                >
                  <Icon name="lucide:reply" class="h-4 w-4" />E-Mail
                </a>
              )}
            </div>

            <dl class="mt-6 divide-y divide-gray-100 border-t border-gray-100">
              {kontakt.map((k) => (
                <div class="flex items-center gap-3 py-3">
                  <Icon name={k.icon} class="h-4 w-4 shrink-0 text-gray-400" />
                  <dt class="w-24 shrink-0 text-xs uppercase tracking-wide text-gray-400">{k.label}</dt>
                  <dd class="min-w-0 flex-1 break-words text-sm text-ink-900">
                    {k.href ? (
                      <a href={k.href} class="hover:text-red-700">
                        {k.wert}
                      </a>
                    ) : (
                      k.wert
                    )}
                  </dd>
                </div>
              ))}
            </dl>
          </div>

          {lead.nachricht && (
            <div class="rounded-[var(--radius-card)] border border-gray-200 bg-white p-6 shadow-soft">
              <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-400">Nachricht</h2>
              <p class="mt-2 whitespace-pre-wrap leading-relaxed text-gray-700">{lead.nachricht}</p>
            </div>
          )}

          {quelle.length > 0 && (
            <div class="rounded-[var(--radius-card)] border border-gray-200 bg-white p-6 shadow-soft">
              <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-400">Herkunft</h2>
              <dl class="mt-3 grid gap-x-6 gap-y-2 sm:grid-cols-2">
                {quelle.map(([k, v]) => (
                  <div class="flex justify-between gap-3 text-sm">
                    <dt class="text-gray-400">{k}</dt>
                    <dd class="min-w-0 truncate text-right text-ink-900">{v}</dd>
                  </div>
                ))}
              </dl>
            </div>
          )}
        </div>

        <aside class="space-y-6">
          <form
            method="POST"
            action="/api/admin/aktion/"
            class="rounded-[var(--radius-card)] border border-gray-200 bg-white p-5 shadow-soft"
          >
            <input type="hidden" name="aktion" value="status" />
            <input type="hidden" name="id" value={lead.id} />
            <label for="status" class="text-sm font-semibold text-ink-900">Status</label>
            <select
              id="status"
              name="status"
              class="mt-2 min-h-11 w-full rounded-lg border border-gray-200 px-3 text-sm text-ink-900 outline-none focus:border-red-600"
            >
              {statusListe.map((o) => <option value={o.v} selected={lead!.status === o.v}>{o.l}</option>)}
            </select>
            <button
              type="submit"
              class="mt-3 inline-flex min-h-11 w-full items-center justify-center gap-2 rounded-full bg-red-600 px-5 text-sm font-semibold text-white hover:bg-red-700"
            >
              <Icon name="lucide:check" class="h-4 w-4" />Status speichern
            </button>
          </form>

          <form
            method="POST"
            action="/api/admin/aktion/"
            class="rounded-[var(--radius-card)] border border-gray-200 bg-white p-5 shadow-soft"
          >
            <input type="hidden" name="aktion" value="notiz" />
            <input type="hidden" name="id" value={lead.id} />
            <label for="notiz" class="text-sm font-semibold text-ink-900">Interne Notiz</label>
            <textarea
              id="notiz"
              name="notiz"
              rows="4"
              placeholder="Nur intern sichtbar …"
              class="mt-2 w-full rounded-lg border border-gray-200 p-3 text-sm text-ink-900 outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100"
              >{lead.interne_notiz ?? ''}</textarea
            >
            <button
              type="submit"
              class="mt-3 inline-flex min-h-11 w-full items-center justify-center gap-2 rounded-full border border-gray-200 px-5 text-sm font-semibold text-ink-900 hover:border-red-600 hover:text-red-700"
            >
              <Icon name="lucide:save" class="h-4 w-4" />Notiz speichern
            </button>
          </form>

          <div class="rounded-[var(--radius-card)] border border-gray-200 bg-white p-5 text-xs text-gray-400 shadow-soft">
            <p>Zuletzt geändert: {formatDatum(lead.updated_at)}</p>
            <p class="mt-1">{mailText}</p>
            <form method="POST" action="/api/admin/aktion/" class="mt-3" data-confirm="Diese Anfrage endgültig löschen?">
              <input type="hidden" name="aktion" value="delete" />
              <input type="hidden" name="id" value={lead.id} />
              <button type="submit" class="inline-flex items-center gap-1.5 font-semibold text-danger hover:underline">
                <Icon name="lucide:trash-2" class="h-3.5 w-3.5" />Anfrage löschen
              </button>
            </form>
          </div>
        </aside>
      </div>
    )
  }
</AdminLayout>
