---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import StatsBand from '../components/sections/StatsBand.astro';
import LeistungenGrid from '../components/sections/LeistungenGrid.astro';
import Gruende from '../components/sections/Gruende.astro';
import Zertifizierung from '../components/sections/Zertifizierung.astro';
import AblaufSteps from '../components/sections/AblaufSteps.astro';
import RegionBand from '../components/sections/RegionBand.astro';
import CtaSection from '../components/sections/CtaSection.astro';
import SchemaGraph from '../components/schema/SchemaGraph.astro';
import { buildHomeGraph } from '../lib/schema';

const origin = Astro.site?.origin ?? 'https://www.asbesta-schadstoffsanierung.de';
const homeGraph = buildHomeGraph(origin);
const title = 'Asbestsanierung Marl & NRW | Asbesta Schadstoffsanierung';
const description =
  'Zertifizierte Asbest- & Schadstoffsanierung nach TRGS 519 aus Marl für ganz NRW – Festpreis, kostenlose Besichtigung und lückenloser Entsorgungsnachweis.';
---

<BaseLayout title={title} description={description}>
  <SchemaGraph slot="head" graph={homeGraph} />
  <Hero />
  <StatsBand />
  <LeistungenGrid />
  <Gruende />
  <Zertifizierung ownerHint />
  <AblaufSteps />
  <RegionBand />
  <CtaSection />
</BaseLayout>
