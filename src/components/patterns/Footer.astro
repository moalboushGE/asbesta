---
import { site } from '../../data/site';
import { standorte } from '../../data/standorte';
---

<footer class="border-t border-gray-200 bg-white">
  <div class="border-b border-gray-200">
    <div class="mx-auto max-w-6xl px-4 py-8 lg:px-8">
      <h2 class="font-sans text-sm font-semibold text-ink-900">Einsatzgebiet</h2>
      <ul class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-sm text-gray-500">
        <li><a href="/standorte/" class="font-semibold text-ink-900 hover:text-red-700">Alle Standorte</a></li>
        {
          standorte.map((s) => (
            <li>
              <a href={`/standorte/${s.slug}/`} class="hover:text-red-700">
                {s.name}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-12 sm:grid-cols-2 lg:grid-cols-4 lg:px-8">
    <div class="sm:col-span-2 lg:col-span-1">
      <span class="font-display text-lg font-semibold text-ink-900">ASBESTA</span>
      <p class="mt-2 text-sm text-gray-500">
        {site.legalName} – inhabergeführter Fachbetrieb für Asbest- und Schadstoffsanierung.
      </p>
      <ul class="mt-4 flex flex-wrap gap-x-4 gap-y-1 text-sm text-gray-500">
        <li><a href="/leistungen/" class="hover:text-red-700">Leistungen</a></li>
        <li><a href="/ratgeber/" class="hover:text-red-700">Ratgeber</a></li>
        <li><a href="/ueber-uns/" class="hover:text-red-700">Über uns</a></li>
        <li><a href="/kontakt/" class="hover:text-red-700">Kontakt</a></li>
      </ul>
    </div>

    <div>
      <h2 class="font-sans text-sm font-semibold text-ink-900">Kontakt</h2>
      <address class="mt-3 space-y-1 text-sm not-italic text-gray-500">
        <p>{site.address.street}</p>
        <p>{site.address.zip} {site.address.city}</p>
        <p><a href={site.phone.href} class="hover:text-red-700">{site.phone.display}</a></p>
      </address>
    </div>

    <div>
      <h2 class="font-sans text-sm font-semibold text-ink-900">Zertifizierung</h2>
      <ul class="mt-3 space-y-1 text-sm text-gray-500">
        {site.certifications.map((c) => <li>{c}</li>)}
      </ul>
    </div>

    <div>
      <h2 class="font-sans text-sm font-semibold text-ink-900">Rechtliches</h2>
      <ul class="mt-3 space-y-1 text-sm text-gray-500">
        <li><a href="/impressum/" class="hover:text-red-700">Impressum</a></li>
        <li><a href="/datenschutz/" class="hover:text-red-700">Datenschutz</a></li>
      </ul>
    </div>
  </div>

  <div
    class="border-t border-gray-200 py-5 pb-[4.5rem] text-center text-xs text-gray-500 md:pb-5"
  >
    © 2026 {site.legalName}. Alle Rechte vorbehalten.
  </div>
</footer>
