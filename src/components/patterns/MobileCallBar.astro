---
import { Icon } from 'astro-icon/components';
import { site } from '../../data/site';
---

<!-- Mobile Sticky-Leiste: bewusst auf Body-Ebene (nicht im Header mit backdrop-blur,
     da backdrop-filter sonst den Bezugsrahmen fuer position:fixed bildet). -->
<div
  class="fixed inset-x-0 bottom-0 z-40 grid grid-cols-2 border-t border-gray-200 bg-white md:hidden"
>
  <a
    href={site.phone.href}
    class="flex items-center justify-center gap-2 py-3 text-sm font-semibold text-ink-900"
  >
    <Icon name="lucide:phone" class="h-5 w-5 text-red-600" />Anrufen
  </a>
  <a
    href={site.whatsapp.href}
    class="flex items-center justify-center gap-2 border-l border-gray-200 py-3 text-sm font-semibold text-ink-900"
  >
    <Icon name="lucide:message-circle" class="h-5 w-5 text-red-600" />WhatsApp
  </a>
</div>
