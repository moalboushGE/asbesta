---
import { Icon } from 'astro-icon/components';
import { site } from '../../data/site';
import Button from '../ui/Button.astro';
import Logo from '../ui/Logo.astro';
---

<header class="sticky top-0 z-40 border-b border-gray-200 bg-white/95 backdrop-blur">
  <div class="hidden bg-ink-900 text-white sm:block">
    <div
      class="mx-auto flex max-w-6xl items-center justify-between px-4 py-1.5 text-xs lg:px-8"
    >
      <span class="text-white/80"
        >Fachbetrieb nach TRGS 519 · Asbest- &amp; Schadstoffsanierung in ganz NRW</span
      >
      <a
        href={site.phone.href}
        class="inline-flex items-center gap-1.5 font-semibold hover:text-red-300"
      >
        <Icon name="lucide:phone" class="h-3.5 w-3.5" />{site.phone.display}
      </a>
    </div>
  </div>
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 lg:px-8">
    <a href="/" class="flex items-center" aria-label="Asbesta Schadstoffsanierung – Startseite">
      <Logo class="h-9 w-auto sm:h-10" />
    </a>

    <nav class="hidden items-center gap-7 md:flex" aria-label="Hauptnavigation">
      {
        site.nav.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium text-gray-700 transition-colors hover:text-red-700"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-4 md:flex">
      <a
        href={site.phone.href}
        class="flex items-center gap-2 text-sm font-semibold text-ink-900 hover:text-red-700"
      >
        <Icon name="lucide:phone" class="h-4 w-4 text-red-600" />{site.phone.display}
      </a>
      <Button href="/kontakt/" variant="primary">Kostenlose Anfrage</Button>
    </div>

    <details class="group relative md:hidden">
      <summary
        class="grid h-10 w-10 cursor-pointer list-none place-items-center rounded-lg border border-gray-200 text-ink-900 [&::-webkit-details-marker]:hidden"
        aria-label="Menü öffnen"
      >
        <Icon name="lucide:menu" class="h-5 w-5 group-open:hidden" />
        <Icon name="lucide:x" class="hidden h-5 w-5 group-open:block" />
      </summary>
      <nav
        class="absolute right-0 top-12 z-50 w-60 rounded-[var(--radius-card)] border border-gray-200 bg-white p-2 shadow-lg"
        aria-label="Mobile Navigation"
      >
        {
          site.nav.map((item) => (
            <a
              href={item.href}
              class="block rounded-md px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 hover:text-red-700"
            >
              {item.label}
            </a>
          ))
        }
        <a
          href={site.phone.href}
          class="mt-1 flex items-center gap-2 rounded-md px-3 py-2 text-sm font-semibold text-ink-900"
        >
          <Icon name="lucide:phone" class="h-4 w-4 text-red-600" />{site.phone.display}
        </a>
        <a
          href="/kontakt/"
          class="mt-1 block rounded-md bg-red-600 px-3 py-2 text-center text-sm font-semibold text-white hover:bg-red-700"
          >Kostenlose Anfrage</a
        >
      </nav>
    </details>
  </div>
</header>
