---
import { Icon } from 'astro-icon/components';
import { site } from '../../data/site';
---

<!-- Persistente Conversion-Leiste (Desktop). Body-Ebene, eigener backdrop-blur unkritisch. -->
<div
  class="fixed inset-x-0 bottom-0 z-40 hidden border-t border-gray-200 bg-white/95 backdrop-blur md:block"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-3 lg:px-8">
    <p class="flex items-center gap-2 text-sm text-gray-700">
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-red-500 opacity-75"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-red-600"></span>
      </span>
      <span class="font-semibold text-ink-900">Kostenlose Besichtigung &amp; Festpreis</span>
      <span class="hidden lg:inline">– Rückmeldung innerhalb von 24 Stunden</span>
    </p>
    <div class="flex items-center gap-2">
      <a
        href={site.phone.href}
        class="inline-flex items-center gap-2 rounded-full border border-gray-200 px-4 py-2 text-sm font-semibold text-ink-900 transition-colors hover:border-red-600 hover:text-red-700"
      >
        <Icon name="lucide:phone" class="h-4 w-4 text-red-600" />{site.phone.display}
      </a>
      <a
        href={site.whatsapp.href}
        class="inline-flex items-center gap-2 rounded-full border border-gray-200 px-4 py-2 text-sm font-semibold text-ink-900 transition-colors hover:border-red-600 hover:text-red-700"
      >
        <Icon name="lucide:message-circle" class="h-4 w-4 text-red-600" />WhatsApp
      </a>
      <a
        href="/kontakt/"
        class="inline-flex items-center gap-2 rounded-full bg-red-600 px-5 py-2 text-sm font-semibold text-white transition-colors hover:bg-red-700"
      >
        <Icon name="lucide:clipboard-list" class="h-4 w-4" />Kostenlose Anfrage
      </a>
    </div>
  </div>
</div>
