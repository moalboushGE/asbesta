---
import { Icon } from 'astro-icon/components';
import { bewertungen, bewertungAggregat, googleReviewsUrl } from '../../data/bewertungen';

/** Echte Google-Rezensionen (Social Proof). Rendert nichts, wenn keine Bewertungen vorliegen –
 *  so wird nie eine leere/erfundene Sektion gezeigt. */
const hat = bewertungen.length > 0;
---

{
  hat && (
    <section id="bewertungen" class="bg-gray-50">
      <div class="mx-auto max-w-6xl px-4 py-16 lg:px-8 lg:py-20">
        <div class="flex flex-wrap items-end justify-between gap-5">
          <div class="max-w-2xl">
            <p class="text-sm font-semibold uppercase tracking-wider text-red-700">Bewertungen</p>
            <h2 class="mt-2 text-3xl sm:text-4xl">Das sagen unsere Kundinnen und Kunden</h2>
          </div>
          <a
            href={googleReviewsUrl}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-3 rounded-full border border-gray-200 bg-white px-5 py-2.5 shadow-soft transition-colors hover:border-red-300"
          >
            <span class="font-display text-2xl font-extrabold text-ink-900">
              {bewertungAggregat.rating.toLocaleString('de-DE', { minimumFractionDigits: 1 })}
            </span>
            <span class="leading-tight">
              <span class="block text-lg leading-none tracking-tight text-red-600" aria-hidden="true">
                ★★★★★
              </span>
              <span class="block text-xs text-gray-500">{bewertungAggregat.anzahl} Google-Rezensionen</span>
            </span>
          </a>
        </div>

        <ul class="mt-9 grid items-start gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {bewertungen.map((b, i) => (
            <li
              class="reveal flex flex-col rounded-[var(--radius-card)] border border-gray-200 bg-white p-6 shadow-soft"
              style={`--reveal-delay: ${(i % 3) * 70}ms`}
            >
              <div class="flex items-center justify-between">
                <span class="text-base leading-none tracking-tight text-red-600" aria-label={`${b.rating} von 5 Sternen`}>
                  ★★★★★
                </span>
                <span class="text-[11px] font-semibold uppercase tracking-wide text-gray-400">Google</span>
              </div>
              <p class="mt-3 text-sm leading-relaxed text-gray-700">„{b.text}“</p>
              <div class="mt-4 flex items-center justify-between gap-3 border-t border-gray-100 pt-3">
                <span class="font-sans text-sm font-semibold text-ink-900">{b.name}</span>
                <span class="shrink-0 text-xs text-gray-500">{b.zeit}</span>
              </div>
            </li>
          ))}
        </ul>

        <p class="mt-7 text-sm">
          <a
            href={googleReviewsUrl}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-1.5 font-semibold text-red-700 hover:underline"
          >
            Alle Bewertungen auf Google ansehen
            <Icon name="lucide:arrow-up-right" class="h-4 w-4" />
          </a>
        </p>
      </div>
    </section>
  )
}
