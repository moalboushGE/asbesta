---
import { Icon } from 'astro-icon/components';
import { bewertungen } from '../../data/inhalte';

const top = bewertungen.slice(0, 3);
---

<section id="bewertungen" class="bg-gray-50">
  <div class="reveal mx-auto max-w-6xl px-4 py-16 lg:px-8 lg:py-24">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-wider text-red-700">Bewertungen</p>
      <h2 class="mt-2 text-3xl sm:text-4xl">Echte Stimmen. Echte Projekte.</h2>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-3">
      {
        top.map((b) => (
          <figure class="flex h-full flex-col rounded-[var(--radius-card)] border border-gray-200 bg-white p-6">
            <div class="flex gap-0.5 text-red-600" role="img" aria-label="Fünf von fünf Sternen">
              {Array.from({ length: 5 }).map(() => (
                <Icon name="lucide:star" class="h-4 w-4 fill-current" />
              ))}
            </div>
            <blockquote class="mt-3 flex-1 text-gray-700">&bdquo;{b.text}&ldquo;</blockquote>
            <figcaption class="mt-4 text-sm font-semibold text-ink-900">
              {b.name}
              <span class="font-normal text-gray-500"> · {b.ort}</span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
