---
import { Icon } from 'astro-icon/components';
import { site } from '../../data/site';
import { leistungen } from '../../data/leistungen';
import Button from '../ui/Button.astro';

const heroSlugs = ['asbestsanierung', 'welleternit-ausbauen', 'kmf-sanierung', 'materialanalyse'];
const heroTiles = heroSlugs
  .map((slug) => leistungen.find((l) => l.slug === slug))
  .filter((l) => l !== undefined);
---

<section class="relative overflow-hidden bg-white">
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-gray-50 to-white"></div>
  <div
    class="relative mx-auto grid max-w-6xl items-center gap-12 px-4 py-14 lg:grid-cols-2 lg:gap-10 lg:px-8 lg:py-20"
  >
    <div>
      <p
        class="inline-flex items-center gap-2 rounded-full bg-ink-900 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-white"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-red-500"></span>Fachbetrieb nach TRGS 519 · aus Marl
      </p>
      <h1 class="mt-5 text-4xl leading-[1.05] sm:text-5xl lg:text-6xl">
        Asbest? <span class="text-red-600">Wir holen Sie da raus</span> – schnell, sicher &amp; professionell.
      </h1>
      <p class="mt-5 max-w-xl text-lg text-gray-700">{site.intro}</p>
      <div class="mt-7 flex flex-wrap gap-3">
        <Button href={site.phone.href} variant="primary">
          <Icon name="lucide:phone" class="h-4 w-4" />Jetzt anrufen
        </Button>
        <Button href="/kontakt/" variant="ghost">
          <Icon name="lucide:clipboard-list" class="h-4 w-4" />Kostenlose Anfrage
        </Button>
      </div>
      <p class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-gray-700">
        <span class="relative flex h-2.5 w-2.5">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-500 opacity-75"></span>
          <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-green-600"></span>
        </span>
        Kurzfristige Termine – auch im Notfall. Rückmeldung innerhalb 24 h.
      </p>
    </div>

    <div class="grid grid-cols-2 gap-3 sm:gap-4">
      {
        heroTiles.map((l) => (
          <a
            href={`/leistungen/${l.slug}/`}
            class="group rounded-[var(--radius-card)] border border-gray-200 bg-white p-5 transition-all hover:-translate-y-0.5 hover:border-red-600 hover:shadow-lg"
          >
            <span class="grid h-11 w-11 place-items-center rounded-lg bg-red-50 text-red-700">
              <Icon name={l.icon} class="h-6 w-6" />
            </span>
            <span class="mt-3 block font-sans font-semibold text-ink-900">{l.title}</span>
            <span class="mt-1 block text-sm text-gray-500">{l.summary}</span>
            <span class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-red-700">
              Details
              <Icon name="lucide:arrow-right" class="h-4 w-4 transition-transform group-hover:translate-x-0.5" />
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
