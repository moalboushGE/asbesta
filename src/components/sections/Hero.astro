---
import { Icon } from 'astro-icon/components';
import { site } from '../../data/site';
import Button from '../ui/Button.astro';
import Badge from '../ui/Badge.astro';
---

<section id="hero" class="bg-white">
  <div class="mx-auto grid max-w-6xl gap-12 px-4 py-14 lg:grid-cols-12 lg:gap-8 lg:px-8 lg:py-20">
    <div class="lg:col-span-7">
      <p
        class="mb-5 inline-flex items-center gap-2 rounded-full border border-gray-200 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-gray-500"
      >
        <span class="h-2 w-2 rounded-full bg-green-500"></span>{site.subClaim}
      </p>
      <h1 class="text-4xl leading-[1.08] sm:text-5xl lg:text-[3.5rem]">{site.claim}</h1>
      <p class="mt-6 max-w-2xl text-lg text-gray-700">{site.intro}</p>

      <div class="mt-8 flex flex-wrap gap-3">
        <Button href={site.phone.href} variant="primary">
          <Icon name="lucide:phone" class="h-4 w-4" />Jetzt anrufen
        </Button>
        <Button href={site.whatsapp.href} variant="ghost">
          <Icon name="lucide:message-circle" class="h-4 w-4" />WhatsApp
        </Button>
        <Button href="#kontakt" variant="ghost">
          <Icon name="lucide:clipboard-list" class="h-4 w-4" />Kostenlose Anfrage
        </Button>
      </div>

      <div class="mt-8 flex flex-wrap gap-2">
        {site.certifications.map((c) => <Badge label={c} />)}
      </div>
    </div>

    <div class="lg:col-span-5">
      <div class="rounded-[var(--radius-card)] border border-gray-200 bg-gray-50 p-6">
        <div
          class="flex aspect-[4/3] items-center justify-center rounded-lg border border-dashed border-gray-400 bg-white text-center text-sm text-gray-500"
        >
          <span class="flex flex-col items-center gap-2">
            <Icon name="lucide:image" class="h-7 w-7 text-gray-400" />
            Echtes Projektfoto folgt
          </span>
        </div>
        <dl class="mt-6 space-y-4">
          <div class="flex items-start gap-3">
            <Icon name="lucide:clock" class="mt-0.5 h-5 w-5 shrink-0 text-green-600" />
            <div>
              <dt class="text-sm font-semibold text-ink-900">Schnelle Rückmeldung</dt>
              <dd class="text-sm text-gray-700">{site.responseTime}</dd>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <Icon name="lucide:map-pin" class="mt-0.5 h-5 w-5 shrink-0 text-green-600" />
            <div>
              <dt class="text-sm font-semibold text-ink-900">Aus Marl – für ganz NRW</dt>
              <dd class="text-sm text-gray-700">
                {site.address.street}, {site.address.zip}
                {site.address.city}
              </dd>
            </div>
          </div>
        </dl>
      </div>
    </div>
  </div>
</section>
