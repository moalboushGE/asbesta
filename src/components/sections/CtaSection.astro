---
import { Icon } from 'astro-icon/components';
import { site } from '../../data/site';
import Button from '../ui/Button.astro';
---

<section id="kontakt" class="bg-ink-900">
  <div class="mx-auto max-w-6xl px-4 py-16 text-center lg:px-8 lg:py-20">
    <h2 class="text-3xl text-white sm:text-4xl">Jetzt kostenlose Anfrage stellen</h2>
    <p class="mx-auto mt-4 max-w-xl text-white/70">
      {site.responseTime}. Kostenfreie Besichtigung vor Ort, transparenter Festpreis – ohne
      versteckte Kosten.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <Button href={site.phone.href} variant="primary">
        <Icon name="lucide:phone" class="h-4 w-4" />{site.phone.display}
      </Button>
      <Button
        href={site.whatsapp.href}
        variant="ghost"
        class="border-white/20 bg-transparent text-white hover:border-white hover:text-white"
      >
        <Icon name="lucide:message-circle" class="h-4 w-4" />WhatsApp
      </Button>
    </div>
  </div>
</section>
