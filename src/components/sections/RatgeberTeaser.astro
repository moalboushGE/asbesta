---
import { Icon } from 'astro-icon/components';
import Figure from '../ui/Figure.astro';
import Button from '../ui/Button.astro';
import { getArtikel } from '../../data/ratgeber';

const beitraege = [
  'asbest-erkennen',
  'asbestsanierung-pflicht-kosten-ablauf',
  'asbestdach-entsorgen-kosten-ablauf',
]
  .map((slug) => getArtikel(slug))
  .filter((a) => a !== undefined);
---

<section class="bg-white">
  <div class="mx-auto max-w-6xl px-4 py-16 lg:px-8 lg:py-24">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-wider text-red-700">Ratgeber</p>
        <h2 class="mt-2 text-3xl sm:text-4xl">Wissenswertes rund um Asbest</h2>
        <p class="mt-4 text-gray-700">
          Verständlich erklärt – von Erkennen über Kosten bis Entsorgung. Aus der Praxis unseres
          sachkundigen Fachbetriebs.
        </p>
      </div>
      <Button href="/ratgeber/" variant="ghost" class="shrink-0">
        Alle Ratgeber
        <Icon name="lucide:arrow-right" class="h-4 w-4 text-red-600" />
      </Button>
    </div>

    <ul class="mt-9 grid gap-5 sm:grid-cols-3">
      {
        beitraege.map((a, i) => (
          <li class="reveal" style={`--reveal-delay: ${i * 80}ms`}>
            <a
              href={`/ratgeber/${a.slug}/`}
              class="group flex h-full flex-col overflow-hidden rounded-[var(--radius-card)] border border-gray-200 bg-white transition-all hover:-translate-y-1 hover:shadow-soft"
            >
              <Figure
                src={a.heroImage}
                alt={a.heroAlt}
                aspect="16/9"
                rounded={false}
                sizes="(min-width: 640px) 30vw, 100vw"
              />
              <div class="flex flex-1 flex-col p-5">
                <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-red-700">
                  <Icon name="lucide:book-open" class="h-3.5 w-3.5" />
                  {a.kategorie}
                </span>
                <h3 class="mt-2 font-sans text-base font-semibold text-ink-900 group-hover:text-red-700">
                  {a.title}
                </h3>
                <p class="mt-2 line-clamp-3 text-sm text-gray-700">{a.excerpt}</p>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
