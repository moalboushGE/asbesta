---
import { Icon } from 'astro-icon/components';
import { standorte } from '../../data/standorte';

/** Einsatzgebiet-Sektion: ehrliche lokale Vertrauens-/SEO-Sektion mit internen Links
 *  zu den Stadt-Landingpages (ersetzt die frühere Bewertungen-Sektion). */
---

<section id="region" class="bg-gray-50">
  <div class="reveal mx-auto max-w-6xl px-4 py-16 lg:px-8 lg:py-24">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-wider text-red-700">Einsatzgebiet</p>
      <h2 class="mt-2 text-3xl sm:text-4xl">Asbestsanierung vor Ort in Ihrer Region</h2>
      <p class="mt-4 text-gray-700">
        Unser Firmensitz ist in Marl – im Einsatz sind wir in ganz Nordrhein-Westfalen. Für diese
        Städte haben wir eigene Standortseiten mit lokalen Infos zu Bausubstanz, Anfahrt und Ablauf:
      </p>
    </div>

    <ul class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-3">
      {
        standorte.map((s, i) => (
          <li class="reveal" style={`--reveal-delay: ${(i % 3) * 60}ms`}>
            <a
              href={`/standorte/${s.slug}/`}
              class="group flex items-center gap-3 rounded-[var(--radius-card)] border border-gray-200 bg-white p-4 transition-all hover:-translate-y-1 hover:border-red-300 hover:shadow-soft"
            >
              <span class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-red-50 text-red-700 transition-transform group-hover:scale-110">
                <Icon name="lucide:map-pin" class="h-5 w-5" />
              </span>
              <span class="min-w-0 flex-1">
                <span class="font-sans font-semibold text-ink-900">{s.name}</span>
                <span class="block text-xs text-gray-500">{s.region}</span>
              </span>
              <Icon
                name="lucide:arrow-right"
                class="h-4 w-4 shrink-0 text-red-600 transition-transform group-hover:translate-x-0.5"
              />
            </a>
          </li>
        ))
      }
    </ul>

    <p class="mt-6 text-sm">
      <a href="/standorte/" class="font-semibold text-red-700 underline"
        >Alle Standorte &amp; das gesamte Einsatzgebiet ansehen</a
      >
    </p>
  </div>
</section>
