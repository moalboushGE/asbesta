---
import { Icon } from 'astro-icon/components';
import { standorte } from '../../data/standorte';
import Button from '../ui/Button.astro';

/** Einsatzgebiet-Sektion: kuratierte Darstellung (Schwerpunkt-Staedte als Karten,
 *  uebrige als ruhige Pills) statt 27 gleicher Kacheln – ehrliche lokale Vertrauens-/SEO-Sektion
 *  mit internen Links zu den Stadt-Landingpages. */
const featuredSlugs = ['marl', 'essen', 'dortmund', 'duesseldorf', 'bochum', 'duisburg'];
const featured = featuredSlugs
  .map((slug) => standorte.find((s) => s.slug === slug))
  .filter((s) => s !== undefined);
const weitere = standorte.filter((s) => !featuredSlugs.includes(s.slug));
---

<section id="region" class="bg-gray-50">
  <div class="mx-auto max-w-6xl px-4 py-16 lg:px-8 lg:py-24">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-wider text-red-700">Einsatzgebiet</p>
        <h2 class="mt-2 text-3xl sm:text-4xl">Asbestsanierung vor Ort in Ihrer Region</h2>
        <p class="mt-4 text-gray-700">
          Unser Firmensitz ist in Marl – im Einsatz sind wir in ganz Nordrhein-Westfalen. Für jede
          Stadt gibt es eine eigene Standortseite mit lokalen Infos zu Bausubstanz, Anfahrt und Ablauf.
        </p>
      </div>
      <Button href="/standorte/" variant="ghost" class="shrink-0">
        Alle Standorte
        <Icon name="lucide:arrow-right" class="h-4 w-4 text-red-600" />
      </Button>
    </div>

    <ul class="mt-9 grid grid-cols-2 gap-3 sm:grid-cols-3">
      {
        featured.map((s, i) => (
          <li class="reveal" style={`--reveal-delay: ${(i % 3) * 70}ms`}>
            <a
              href={`/standorte/${s.slug}/`}
              class="group flex items-center gap-3 rounded-[var(--radius-card)] border border-gray-200 bg-white p-4 transition-all hover:-translate-y-1 hover:border-red-300 hover:shadow-soft"
            >
              <span class="grid h-11 w-11 shrink-0 place-items-center rounded-full bg-red-50 text-red-700 transition-transform group-hover:scale-110">
                <Icon name="lucide:map-pin" class="h-5 w-5" />
              </span>
              <span class="min-w-0 flex-1">
                <span class="font-sans font-semibold text-ink-900">{s.name}</span>
                <span class="block text-xs text-gray-500">{s.region}</span>
              </span>
              <Icon
                name="lucide:arrow-right"
                class="h-4 w-4 shrink-0 text-red-600 transition-transform group-hover:translate-x-0.5"
              />
            </a>
          </li>
        ))
      }
    </ul>

    <p class="mt-8 text-sm font-semibold text-ink-900">Weitere Einsatzorte in NRW</p>
    <ul class="mt-3 flex flex-wrap gap-2">
      {
        weitere.map((s) => (
          <li>
            <a
              href={`/standorte/${s.slug}/`}
              class="inline-flex items-center gap-1.5 rounded-full border border-gray-200 bg-white py-1.5 pl-2.5 pr-3.5 text-sm text-gray-700 transition-colors hover:border-red-300 hover:text-red-700"
            >
              <Icon name="lucide:map-pin" class="h-3.5 w-3.5 text-red-600" />
              {s.name}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
