---
import { Icon } from 'astro-icon/components';
import Figure from '../ui/Figure.astro';
import { owner, qualifikationen } from '../../data/site';
import { zertifikatImage } from '../../data/images';

/** Formatiert ein ISO-Datum (YYYY-MM-DD) als "MM/YYYY". */
function monthYear(iso: string): string {
  const [year, month] = iso.split('-');
  return `${month}/${year}`;
}
---

<section id="qualifikationen" class="scroll-mt-24 bg-gray-50">
  <div class="reveal mx-auto max-w-6xl px-4 py-14 lg:px-8 lg:py-16">
    <p class="text-sm font-semibold uppercase tracking-wider text-red-700">Geprüfte Sachkunde</p>
    <h2 class="mt-2 text-2xl sm:text-3xl">Qualifikationen des Inhabers</h2>
    <p class="mt-4 max-w-3xl text-gray-700">{owner.bio}</p>

    <div class="mt-9 grid gap-5 sm:grid-cols-2">
      {
        qualifikationen.map((q) => (
          <article class="flex gap-5 rounded-[var(--radius-card)] border border-gray-200 bg-white p-5">
            <div class="flex shrink-0 flex-col gap-2">
              {q.images.map((slug) => {
                const img = zertifikatImage(slug);
                return (
                  <a
                    href={img.src.src}
                    target="_blank"
                    rel="noopener"
                    class="block w-20 ring-1 ring-black/5 transition hover:ring-2 hover:ring-red-500/60"
                    aria-label={`Zertifikat „${q.title}“ in voller Größe öffnen`}
                  >
                    <Figure
                      src={img.src}
                      alt={img.alt}
                      aspect="3/4"
                      widths={[160, 320]}
                      sizes="80px"
                    />
                  </a>
                );
              })}
            </div>
            <div class="min-w-0">
              <h3 class="font-sans text-base font-semibold text-ink-900">{q.title}</h3>
              <p class="mt-1 flex items-center gap-1.5 text-sm text-gray-500">
                <Icon name="lucide:building-2" class="h-4 w-4 shrink-0" />
                {q.issuer}
              </p>
              <p class="mt-2 text-sm text-gray-700">{q.note}</p>
              {q.validUntil && (
                <span class="mt-3 inline-flex items-center gap-1.5 rounded-full bg-red-50 px-3 py-1 text-xs font-semibold text-red-700">
                  <Icon name="lucide:badge-check" class="h-3.5 w-3.5" />
                  gültig bis {monthYear(q.validUntil)}
                </span>
              )}
            </div>
          </article>
        ))
      }
    </div>

    <p class="mt-6 max-w-3xl text-xs text-gray-500">
      Original-Bescheinigungen liegen vor und können auf Wunsch eingesehen werden. Zum Schutz
      personenbezogener Daten ist das Geburtsdatum auf den abgebildeten Scans geschwärzt.
    </p>
  </div>
</section>
