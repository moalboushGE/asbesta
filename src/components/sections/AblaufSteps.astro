---
import { ablauf } from '../../data/inhalte';
import { ablaufImage } from '../../data/images';
import Figure from '../ui/Figure.astro';
---

<section id="ablauf" class="bg-white">
  <div class="reveal mx-auto max-w-6xl px-4 py-16 lg:px-8 lg:py-24">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-wider text-red-700">Ablauf</p>
      <h2 class="mt-2 text-3xl sm:text-4xl">In fünf Schritten zur sauberen Übergabe</h2>
    </div>

    <ol class="mt-10 grid gap-6 sm:grid-cols-2 md:grid-cols-5">
      {
        ablauf.map((s, i) => {
          const img = ablaufImage(i);
          return (
            <li
              class="ablauf-step reveal group overflow-hidden rounded-[var(--radius-card)] border border-gray-200 bg-white transition-all hover:-translate-y-1 hover:shadow-soft"
              style={`--reveal-delay: ${i * 80}ms`}
            >
              <div class="relative">
                <Figure
                  src={img.src}
                  alt={img.alt}
                  aspect="4/3"
                  rounded={false}
                  sizes="(min-width: 768px) 18vw, (min-width: 640px) 45vw, 100vw"
                />
                <span class="absolute left-3 top-3 grid h-9 w-9 place-items-center rounded-full bg-red-600 font-display text-sm font-bold text-white shadow-soft">
                  {s.nr}
                </span>
              </div>
              <div class="p-5">
                <h3 class="font-sans text-base font-semibold text-ink-900">{s.title}</h3>
                <p class="mt-1.5 text-sm text-gray-700">{s.text}</p>
              </div>
            </li>
          );
        })
      }
    </ol>
  </div>

  <style>
    .ablauf-step :global(img) {
      transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .ablauf-step:hover :global(img) {
      transform: scale(1.06);
    }
  </style>
</section>
