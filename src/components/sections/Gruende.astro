---
import { Icon } from 'astro-icon/components';

const punkte = [
  {
    nr: '01',
    icon: 'lucide:badge-check',
    title: 'Zertifizierter Fachbetrieb',
    text: 'Sanierung nach TRGS 519/521/524, Fachbetrieb nach GefStoffV – mit sachkundigem Personal und voller Betriebshaftpflicht.',
    dark: true,
  },
  {
    nr: '02',
    icon: 'lucide:wallet',
    title: 'Fairer Festpreis',
    text: 'Kostenlose Besichtigung, transparentes Festpreis-Angebot – ohne versteckte Kosten und ohne Überraschungen.',
    dark: false,
  },
  {
    nr: '03',
    icon: 'lucide:clock',
    title: 'Antwort in 24 Stunden',
    text: 'Kurzfristige Termine, auch im Notfall. Verbindliche Zusagen und eine garantierte, dokumentierte Übergabe.',
    dark: false,
  },
];
---

<section class="bg-gray-50">
  <div class="reveal mx-auto max-w-6xl px-4 py-16 lg:px-8 lg:py-24">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-wider text-red-700">Warum Asbesta</p>
      <h2 class="mt-2 text-3xl sm:text-4xl">Drei Dinge, die zählen.</h2>
      <p class="mt-4 text-gray-700">
        Statt großer Versprechen: klare Zusagen, auf die Sie sich von der Anfrage bis zur Übergabe
        verlassen können.
      </p>
    </div>
    <div class="mt-10 grid gap-4 md:grid-cols-3">
      {
        punkte.map((p) => (
          <div
            class:list={[
              'rounded-[var(--radius-card)] p-7',
              p.dark ? 'bg-ink-900 text-white' : 'border border-gray-200 bg-white',
            ]}
          >
            <div class="flex items-center justify-between">
              <span
                class:list={[
                  'grid h-11 w-11 place-items-center rounded-lg',
                  p.dark ? 'bg-white/10 text-red-300' : 'bg-red-50 text-red-700',
                ]}
              >
                <Icon name={p.icon} class="h-6 w-6" />
              </span>
              <span
                aria-hidden="true"
                class:list={[
                  'font-display text-3xl font-extrabold',
                  p.dark ? 'text-red-300' : 'text-red-600',
                ]}
              >
                {p.nr}
              </span>
            </div>
            <h3 class:list={['mt-5 font-sans text-lg font-semibold', p.dark ? 'text-white' : 'text-ink-900']}>
              {p.title}
            </h3>
            <p class:list={['mt-2 text-sm', p.dark ? 'text-white/70' : 'text-gray-700']}>{p.text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
