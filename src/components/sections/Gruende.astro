---
import { Icon } from 'astro-icon/components';
import { gruende } from '../../data/inhalte';
---

<section class="bg-gray-50">
  <div class="reveal mx-auto max-w-6xl px-4 py-16 lg:px-8 lg:py-24">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-wider text-red-700">Warum Asbesta</p>
      <h2 class="mt-2 text-3xl sm:text-4xl">Sechs Gründe, warum Kunden uns weiterempfehlen</h2>
    </div>

    <div class="mt-10 grid gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
      {
        gruende.map((g) => (
          <div class="flex gap-4">
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-lg bg-white text-red-700 ring-1 ring-gray-200">
              <Icon name={g.icon} class="h-6 w-6" />
            </span>
            <div>
              <h3 class="font-sans text-lg font-semibold text-ink-900">{g.title}</h3>
              <p class="mt-1.5 text-sm text-gray-700">{g.text}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
