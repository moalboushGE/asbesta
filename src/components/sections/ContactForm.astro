---
import { Icon } from 'astro-icon/components';
import { leistungen } from '../../data/leistungen';
import { site, waLink } from '../../data/site';

const waText = 'Hallo Asbesta, ich habe eine Anfrage zur Asbest-/Schadstoffsanierung.';
const field =
  'mt-1 w-full rounded-[var(--radius-btn)] border border-gray-200 bg-white px-3 py-2.5 text-ink-900 placeholder:text-gray-400 focus-visible:border-red-600';
const labelCls = 'block text-sm font-semibold text-ink-900';
---

<form id="anfrage-form" class="space-y-4" novalidate data-anfrage-form>
  <!-- Honeypot (fuer Menschen unsichtbar) -->
  <input
    type="text"
    name="website"
    tabindex="-1"
    autocomplete="off"
    class="hidden"
    aria-hidden="true"
  />
  <input type="hidden" name="ts" />
  <input type="hidden" name="typ" value="anfrage" />
  <input type="hidden" name="utm_source" />
  <input type="hidden" name="utm_medium" />
  <input type="hidden" name="utm_campaign" />
  <input type="hidden" name="gclid" />
  <input type="hidden" name="landingpage" />
  <input type="hidden" name="referrer" />

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <label class={labelCls} for="f-name">Name*</label>
      <input class={field} id="f-name" name="name" required maxlength="100" autocomplete="name" enterkeyhint="next" />
    </div>
    <div>
      <label class={labelCls} for="f-telefon">Telefon</label>
      <input class={field} id="f-telefon" name="telefon" type="tel" inputmode="tel" maxlength="40" autocomplete="tel" enterkeyhint="next" />
    </div>
    <div>
      <label class={labelCls} for="f-email">E-Mail*</label>
      <input class={field} id="f-email" name="email" type="email" inputmode="email" required maxlength="150" autocomplete="email" enterkeyhint="next" />
    </div>
    <div>
      <label class={labelCls} for="f-ort">Ort</label>
      <input class={field} id="f-ort" name="ort" maxlength="100" autocomplete="address-level2" enterkeyhint="next" />
    </div>
  </div>

  <div>
    <label class={labelCls} for="f-dienstleistung">Dienstleistung</label>
    <select class={field} id="f-dienstleistung" name="dienstleistung">
      <option value="">Bitte wählen …</option>
      {leistungen.map((l) => <option value={l.title}>{l.title}</option>)}
      <option value="Sonstiges">Sonstiges / unklar</option>
    </select>
  </div>

  <div>
    <label class={labelCls} for="f-nachricht">Nachricht*</label>
    <textarea class={field} id="f-nachricht" name="nachricht" rows="5" required maxlength="2000"></textarea>
  </div>

  <label class="flex items-start gap-2.5 text-sm text-gray-700">
    <input type="checkbox" name="einwilligung" value="ja" required class="mt-0.5 h-4 w-4" />
    <span>
      Ich willige ein, dass meine Angaben zur Bearbeitung meiner Anfrage verarbeitet werden. Es
      gelten unsere <a href="/datenschutz/" class="text-red-700 underline">Datenschutzhinweise</a>.*
    </span>
  </label>

  <button
    type="submit"
    class="inline-flex min-h-11 items-center justify-center gap-2 rounded-full bg-red-600 px-6 py-3 text-sm font-semibold text-white shadow-soft-red transition-colors hover:bg-red-700"
    >Anfrage senden</button
  >
  <p class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-gray-500">
    <span class="inline-flex items-center gap-1">
      <Icon name="lucide:shield-check" class="h-3.5 w-3.5 text-red-600" />Kostenlos &amp; unverbindlich
    </span>
    <span class="inline-flex items-center gap-1">
      <Icon name="lucide:badge-check" class="h-3.5 w-3.5 text-red-600" />Sachkunde TRGS 519
    </span>
    <span class="inline-flex items-center gap-1">
      <Icon name="lucide:clock" class="h-3.5 w-3.5 text-red-600" />Antwort in 24 h
    </span>
    <span class="inline-flex items-center gap-1">
      <Icon name="lucide:lock" class="h-3.5 w-3.5 text-red-600" />Daten nur an uns
    </span>
  </p>

  <p data-status role="status" aria-live="polite" class="text-sm font-medium text-gray-700"></p>
  <p class="text-xs text-gray-500">
    Lieber direkt? Telefon
    <a href={site.phone.href} class="text-red-700 underline" data-conv="call">{site.phone.display}</a> ·
    Fotos gern per
    <a href={waLink(waText)} class="text-red-700 underline" data-conv="whatsapp">WhatsApp</a>.
    Pflichtfelder*
  </p>
</form>
