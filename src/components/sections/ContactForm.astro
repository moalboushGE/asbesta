---
import { leistungen } from '../../data/leistungen';
import { site } from '../../data/site';

const field =
  'mt-1 w-full rounded-[var(--radius-btn)] border border-gray-200 bg-white px-3 py-2.5 text-ink-900 placeholder:text-gray-400 focus-visible:border-red-600 focus-visible:outline-none';
const labelCls = 'block text-sm font-semibold text-ink-900';
---

<form id="anfrage-form" class="space-y-4" novalidate>
  <!-- Honeypot (fuer Menschen unsichtbar) -->
  <input
    type="text"
    name="website"
    tabindex="-1"
    autocomplete="off"
    class="hidden"
    aria-hidden="true"
  />
  <input type="hidden" name="ts" />

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <label class={labelCls} for="f-name">Name*</label>
      <input class={field} id="f-name" name="name" required autocomplete="name" />
    </div>
    <div>
      <label class={labelCls} for="f-telefon">Telefon</label>
      <input class={field} id="f-telefon" name="telefon" type="tel" autocomplete="tel" />
    </div>
    <div>
      <label class={labelCls} for="f-email">E-Mail*</label>
      <input class={field} id="f-email" name="email" type="email" required autocomplete="email" />
    </div>
    <div>
      <label class={labelCls} for="f-ort">Ort</label>
      <input class={field} id="f-ort" name="ort" autocomplete="address-level2" />
    </div>
  </div>

  <div>
    <label class={labelCls} for="f-dienstleistung">Dienstleistung</label>
    <select class={field} id="f-dienstleistung" name="dienstleistung">
      <option value="">Bitte wählen …</option>
      {leistungen.map((l) => <option value={l.title}>{l.title}</option>)}
      <option value="Sonstiges">Sonstiges / unklar</option>
    </select>
  </div>

  <div>
    <label class={labelCls} for="f-nachricht">Nachricht*</label>
    <textarea class={field} id="f-nachricht" name="nachricht" rows="5" required></textarea>
  </div>

  <label class="flex items-start gap-2.5 text-sm text-gray-700">
    <input type="checkbox" name="einwilligung" value="ja" required class="mt-0.5 h-4 w-4" />
    <span>
      Ich willige ein, dass meine Angaben zur Bearbeitung meiner Anfrage verarbeitet werden. Es
      gelten unsere <a href="/datenschutz/" class="text-red-700 underline">Datenschutzhinweise</a>.*
    </span>
  </label>

  <button
    type="submit"
    class="inline-flex min-h-11 items-center justify-center gap-2 rounded-[var(--radius-btn)] bg-red-600 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-red-700"
    >Anfrage senden</button
  >

  <p id="anfrage-status" role="status" aria-live="polite" class="text-sm font-medium text-gray-700"></p>
  <p class="text-xs text-gray-500">
    Lieber direkt? Telefon <a href={site.phone.href} class="text-red-700">{site.phone.display}</a> ·
    Fotos gern per <a href={site.whatsapp.href} class="text-red-700">WhatsApp</a>. Pflichtfelder*
  </p>
</form>

<script>
  const form = document.getElementById('anfrage-form');
  if (form instanceof HTMLFormElement) {
    const tsInput = form.querySelector('input[name="ts"]');
    if (tsInput instanceof HTMLInputElement) tsInput.value = String(Date.now());

    const statusEl = document.getElementById('anfrage-status');
    const setStatus = (msg: string): void => {
      if (statusEl) statusEl.textContent = msg;
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      setStatus('Wird gesendet …');
      try {
        const response = await fetch('/api/anfrage', { method: 'POST', body: new FormData(form) });
        const data = await response.json();
        if (data && data.ok) {
          form.reset();
          setStatus('Vielen Dank! Wir melden uns innerhalb von 24 Stunden bei Ihnen.');
        } else {
          setStatus('Bitte prüfen Sie Ihre Eingaben – oder rufen Sie uns an: +49 2365 2960630.');
        }
      } catch {
        setStatus('Senden derzeit nicht möglich. Bitte rufen Sie uns an: +49 2365 2960630.');
      }
    });
  }
</script>
