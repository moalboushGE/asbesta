---
import { Icon } from 'astro-icon/components';

const stats = [
  { icon: 'lucide:building-2', value: '1.000+', label: 'abgeschlossene Projekte' },
  { icon: 'lucide:calendar-clock', value: '15+', label: 'Jahre Erfahrung' },
  { icon: 'lucide:shield-check', value: '100 %', label: 'zertifiziert & versichert' },
  { icon: 'lucide:map-pin', value: 'NRW', label: 'im Einsatz in ganz Nordrhein-Westfalen' },
];
---

<section aria-label="Kennzahlen" class="border-y border-gray-200 bg-gray-50">
  <div
    class="reveal mx-auto grid max-w-6xl grid-cols-2 divide-x divide-y divide-gray-200 lg:grid-cols-4 lg:divide-y-0"
  >
    {
      stats.map((s) => (
        <div class="flex flex-col items-center gap-2 px-4 py-8 text-center">
          <Icon name={s.icon} class="h-6 w-6 text-red-600" />
          <span class="font-display text-3xl font-extrabold text-ink-900 sm:text-4xl">{s.value}</span>
          <span class="text-sm text-gray-700">{s.label}</span>
        </div>
      ))
    }
  </div>
</section>
