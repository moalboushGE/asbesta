---
import { site } from '../../data/site';
---

<section aria-label="Kennzahlen" class="border-y border-gray-200 bg-ink-900">
  <div
    class="reveal mx-auto grid max-w-6xl grid-cols-1 divide-y divide-white/10 px-4 sm:grid-cols-3 sm:divide-x sm:divide-y-0 lg:px-8"
  >
    {
      site.stats.map((s) => (
        <div class="flex flex-col items-center gap-1 py-8 text-center">
          <span class="font-display text-4xl font-semibold text-white">{s.value}</span>
          <span class="text-sm text-white/70">{s.label}</span>
        </div>
      ))
    }
  </div>
</section>
