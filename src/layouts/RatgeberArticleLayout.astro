---
import { Icon } from 'astro-icon/components';
import BaseLayout from './BaseLayout.astro';
import SchemaGraph from '../components/schema/SchemaGraph.astro';
import Breadcrumb from '../components/patterns/Breadcrumb.astro';
import Figure from '../components/ui/Figure.astro';
import CtaSection from '../components/sections/CtaSection.astro';
import { buildArticleGraph } from '../lib/schema';
import { leistungenFuerRatgeber, verwandteRatgeber } from '../lib/related';
import { type RatgeberArtikel, ratgeberArtikel, getArtikel } from '../data/ratgeber';
import { leistungen } from '../data/leistungen';
import { qualifikationen } from '../data/site';

interface TocItem {
  readonly id: string;
  readonly label: string;
}

interface Props {
  readonly artikel: RatgeberArtikel;
  readonly toc?: readonly TocItem[];
}

const { artikel, toc = [] } = Astro.props;
const path = `/ratgeber/${artikel.slug}/`;
const origin = Astro.site?.origin ?? 'https://www.asbesta-schadstoffsanierung.de';

const datum = new Intl.DateTimeFormat('de-DE', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(new Date(artikel.datePublished));

const heroOg = new URL(artikel.heroImage.src, origin).href;
const graph = buildArticleGraph({
  origin,
  title: artikel.title,
  description: artikel.metaDescription,
  path,
  image: heroOg,
  imageWidth: artikel.heroImage.width,
  imageHeight: artikel.heroImage.height,
  kategorie: artikel.kategorie,
  datePublished: artikel.datePublished,
  dateModified: artikel.dateModified,
  author: artikel.author,
  faqs: artikel.faqs,
});

const aktualisiert =
  artikel.dateModified && artikel.dateModified !== artikel.datePublished
    ? new Intl.DateTimeFormat('de-DE', { day: 'numeric', month: 'long', year: 'numeric' }).format(
        new Date(artikel.dateModified),
      )
    : null;

const verwandt = leistungenFuerRatgeber(artikel.slug)
  .slice(0, 3)
  .map((slug) => leistungen.find((l) => l.slug === slug))
  .filter((l) => l !== undefined);

// Weitere Beiträge: thematisch verwandte Ratgeber (Fallback: neueste 3).
const verwandteSlugs = verwandteRatgeber(artikel.slug);
const weitereBeitraege = (
  verwandteSlugs.length > 0
    ? verwandteSlugs.map((s) => getArtikel(s)).filter((a) => a !== undefined)
    : ratgeberArtikel.filter((a) => a.slug !== artikel.slug).slice(0, 3)
).filter((a) => a.slug !== artikel.slug);
const kernNachweis = qualifikationen[0]?.title ?? 'Sachkunde nach TRGS 519, Anlage 3';
---

<BaseLayout
  title={artikel.metaTitle}
  description={artikel.metaDescription}
  ogType="article"
  articlePublished={artikel.datePublished}
  articleModified={artikel.dateModified}
  articleAuthor={artikel.author}
>
  <SchemaGraph slot="head" graph={graph} />

  <article>
    <header class="border-b border-gray-200 bg-gradient-to-br from-red-50 via-white to-gray-50">
      <div class="mx-auto max-w-3xl px-4 py-10 lg:px-8 lg:py-14">
        <Breadcrumb
          items={[
            { name: 'Start', href: '/' },
            { name: 'Ratgeber', href: '/ratgeber/' },
            { name: artikel.title },
          ]}
        />
        <p class="mt-6">
          <span
            class="inline-flex items-center gap-1.5 rounded-full bg-red-50 px-3 py-1 text-xs font-semibold text-red-700"
          >
            <Icon name="lucide:book-open" class="h-3.5 w-3.5" />{artikel.kategorie}
          </span>
        </p>
        <h1 class="mt-4 text-3xl leading-tight sm:text-4xl lg:text-5xl">{artikel.title}</h1>
        <p class="mt-5 text-lg text-gray-700">{artikel.excerpt}</p>
        <div class="mt-6 flex flex-wrap items-center gap-x-2.5 gap-y-1 text-sm text-gray-500">
          <span class="font-semibold text-ink-900">Von {artikel.author}</span>
          <span class="text-gray-500">({artikel.authorRole})</span>
          <span aria-hidden="true">·</span>
          <time datetime={artikel.datePublished}>{datum}</time>
          <span aria-hidden="true">·</span>
          <span>{artikel.lesezeitMin} min Lesezeit</span>
          {
            aktualisiert && (
              <>
                <span aria-hidden="true">·</span>
                <span>Aktualisiert am {aktualisiert}</span>
              </>
            )
          }
        </div>
      </div>
    </header>

    <div class="mx-auto max-w-3xl px-4 pt-8 lg:px-8">
      <Figure
        src={artikel.heroImage}
        alt={artikel.heroAlt}
        aspect="16/9"
        priority
        sizes="(min-width: 768px) 768px, 100vw"
        class="shadow-sm ring-1 ring-black/5"
      />
    </div>

    {
      toc.length > 0 && (
        <nav aria-label="Inhaltsverzeichnis" class="mx-auto mt-8 max-w-3xl px-4 lg:px-8">
          <div class="rounded-[var(--radius-card)] border border-gray-200 bg-gray-50 p-5">
            <p class="font-sans text-sm font-semibold uppercase tracking-wider text-red-700">
              Inhalt
            </p>
            <ol class="mt-3 grid gap-1.5 sm:grid-cols-2">
              {toc.map((t, i) => (
                <li>
                  <a
                    href={`#${t.id}`}
                    class="inline-flex items-baseline gap-2 text-sm text-gray-700 transition-colors hover:text-red-700"
                  >
                    <span class="font-semibold tabular-nums text-red-600">{String(i + 1).padStart(2, '0')}</span>
                    {t.label}
                  </a>
                </li>
              ))}
            </ol>
          </div>
        </nav>
      )
    }

    <div
      class="ratgeber-prose mx-auto mt-8 max-w-3xl px-4 lg:px-8 [&>h2]:mt-12 [&>h2]:scroll-mt-24 [&>h2]:text-2xl [&>h2]:sm:text-3xl [&>h3]:mt-8 [&>h3]:font-sans [&>h3]:text-lg [&>h3]:font-semibold [&>h3]:text-ink-900 [&>p]:mt-4 [&>p]:leading-relaxed [&>p]:text-gray-700 [&>ul]:mt-4 [&>ul]:list-disc [&>ul]:pl-6 [&>ul]:text-gray-700 [&>ol]:mt-4 [&>ol]:list-decimal [&>ol]:pl-6 [&>ol]:text-gray-700 [&_li]:mt-1.5 [&_a]:font-medium [&_a]:text-red-700 [&_a]:underline [&_table]:w-full [&_table]:border-collapse [&_table]:text-sm [&_th]:border [&_th]:border-gray-200 [&_th]:bg-gray-50 [&_th]:p-3 [&_th]:text-left [&_th]:align-top [&_th]:font-semibold [&_th]:text-ink-900 [&_td]:border [&_td]:border-gray-200 [&_td]:p-3 [&_td]:align-top [&_td]:text-gray-700"
    >
      <slot />
    </div>

    <section class="mx-auto max-w-3xl px-4 lg:px-8">
      <h2 class="mt-12 text-2xl sm:text-3xl">Häufige Fragen</h2>
      <div class="cv-auto mt-5 divide-y divide-gray-200 border-y border-gray-200">
        {
          artikel.faqs.map((faq, i) => (
            <details class="group py-4" open={i === 0}>
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-sans font-semibold text-ink-900 [&::-webkit-details-marker]:hidden">
                <span>{faq.frage}</span>
                <Icon
                  name="lucide:plus"
                  class="h-5 w-5 shrink-0 text-red-600 transition-transform group-open:rotate-45"
                />
              </summary>
              <p class="mt-3 leading-relaxed text-gray-700">{faq.antwort}</p>
            </details>
          ))
        }
      </div>
    </section>

    <section class="mx-auto max-w-3xl px-4 pt-10 lg:px-8">
      <div
        class="flex flex-col gap-4 rounded-[var(--radius-card)] border border-gray-200 bg-gray-50 p-6 sm:flex-row sm:items-center"
      >
        <span class="grid h-12 w-12 shrink-0 place-items-center rounded-full bg-red-50 text-red-700">
          <Icon name="lucide:shield-check" class="h-6 w-6" />
        </span>
        <div>
          <p class="font-sans font-semibold text-ink-900">Über {artikel.author}</p>
          <p class="mt-1 text-sm leading-relaxed text-gray-700">
            {artikel.author} ist {artikel.authorRole} und führt die Asbesta Schadstoffsanierung. Wir
            sanieren Asbest und Schadstoffe in ganz Nordrhein-Westfalen und geben
            unser Wissen aus der Praxis weiter. Dieser Beitrag dient der Orientierung und ersetzt
            keine rechtliche Beratung im Einzelfall.
          </p>
          <p class="mt-2 text-sm">
            <span class="text-gray-500">Nachweis: {kernNachweis}.</span>{' '}
            <a
              href="/ueber-uns/#qualifikationen"
              class="font-semibold text-red-700 underline-offset-2 hover:underline"
            >
              Qualifikationen &amp; Nachweise ansehen
            </a>
          </p>
        </div>
      </div>

      {
        artikel.quellen && artikel.quellen.length > 0 && (
          <div class="mt-10 rounded-[var(--radius-card)] border border-gray-200 bg-gray-50 p-5">
            <p class="flex items-center gap-2 font-sans text-sm font-semibold text-ink-900">
              <Icon name="lucide:book-marked" class="h-4 w-4 text-red-600" />
              Quellen &amp; weiterführende Informationen
            </p>
            <ul class="mt-2 space-y-1 text-sm text-gray-700">
              {artikel.quellen.map((q) => (
                <li>
                  <a
                    href={q.url}
                    target="_blank"
                    rel="noopener"
                    class="font-medium text-red-700 underline-offset-2 hover:underline"
                  >
                    {q.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      <h2 class="mt-12 text-xl">Passende Leistungen</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {
          verwandt.map((l) => (
            <li>
              <a
                href={`/leistungen/${l.slug}/`}
                class="inline-flex items-center gap-1.5 rounded-full border border-gray-200 bg-white min-h-11 px-3.5 py-2 text-sm text-gray-700 transition-colors hover:border-red-600 hover:text-red-700"
              >
                <Icon name={l.icon} class="h-4 w-4 text-red-600" />
                {l.title}
              </a>
            </li>
          ))
        }
        <li>
          <a
            href="/standorte/"
            class="inline-flex items-center gap-1.5 rounded-full border border-gray-200 bg-white min-h-11 px-3.5 py-2 text-sm text-gray-700 transition-colors hover:border-red-600 hover:text-red-700"
          >
            <Icon name="lucide:map-pin" class="h-4 w-4 text-red-600" />
            Asbestsanierung in Ihrer Stadt (NRW)
          </a>
        </li>
        <li>
          <a
            href="/wissen/"
            class="inline-flex items-center gap-1.5 rounded-full border border-gray-200 bg-white min-h-11 px-3.5 py-2 text-sm text-gray-700 transition-colors hover:border-red-600 hover:text-red-700"
          >
            <Icon name="lucide:book-marked" class="h-4 w-4 text-red-600" />
            Begriffe &amp; Daten im Wissens-Glossar
          </a>
        </li>
      </ul>

      {
        weitereBeitraege.length > 0 && (
          <>
            <h2 class="mt-12 text-xl">Weitere Beiträge</h2>
            <ul class="mt-4 grid gap-3 sm:grid-cols-3">
              {weitereBeitraege.map((a) => (
                <li>
                  <a
                    href={`/ratgeber/${a.slug}/`}
                    class="group flex h-full flex-col rounded-[var(--radius-card)] border border-gray-200 bg-white p-4 transition-colors hover:border-red-600"
                  >
                    <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-red-700">
                      <Icon name="lucide:book-open" class="h-3.5 w-3.5" />
                      {a.kategorie}
                    </span>
                    <span class="mt-2 font-sans text-sm font-semibold text-ink-900 group-hover:text-red-700">
                      {a.title}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </>
        )
      }
    </section>

    <div class="mt-12">
      <CtaSection />
    </div>
  </article>
</BaseLayout>
