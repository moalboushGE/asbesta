---
// Performance: nur 3 Schriftschnitte (400 Body, 600 Akzent, 900 Headings), self-gehostet mit
// font-display: optional -> KEIN Font-Swap-Reflow (CLS-stabil; Barlow ist vorgeladen). 500/700/800
// werden in global.css auf geladene Schnitte gemappt. Latin + Latin-Ext decken deutschen Content;
// seltene Zeichen (Vietnamesisch, Sterne) nutzen den metrik-angepassten Fallback aus global.css.
import barlowBody from '@fontsource/barlow/files/barlow-latin-400-normal.woff2?url';
import barlowHeading from '@fontsource/barlow/files/barlow-latin-900-normal.woff2?url';
import barlowAccent from '@fontsource/barlow/files/barlow-latin-600-normal.woff2?url';
import barlowExt400 from '@fontsource/barlow/files/barlow-latin-ext-400-normal.woff2?url';
import barlowExt600 from '@fontsource/barlow/files/barlow-latin-ext-600-normal.woff2?url';
import barlowExt900 from '@fontsource/barlow/files/barlow-latin-ext-900-normal.woff2?url';
import '../styles/global.css';
import Header from '../components/patterns/Header.astro';
import Footer from '../components/patterns/Footer.astro';
import DesktopCtaBar from '../components/patterns/DesktopCtaBar.astro';
import MobileCallBar from '../components/patterns/MobileCallBar.astro';
import { CF_ANALYTICS_TOKEN } from '../lib/config';

interface Props {
  readonly title: string;
  readonly description: string;
  /** Index-Gate: true setzt <meta robots noindex,follow> (z. B. fuer noch duenne Seiten). */
  readonly noindex?: boolean;
  /** og:type – 'website' (Default) oder 'article' (Ratgeber-Beiträge). */
  readonly ogType?: 'website' | 'article';
  /** Absolute Bild-URL für og:image/twitter:image (Default: globales og.png). */
  readonly ogImage?: string;
  /** Nur bei ogType 'article': ISO-Daten + Autor für article:*-OG-Meta. */
  readonly articlePublished?: string;
  readonly articleModified?: string;
  readonly articleAuthor?: string;
}

const {
  title,
  description,
  noindex = false,
  ogType = 'website',
  ogImage: ogImageProp,
  articlePublished,
  articleModified,
  articleAuthor,
} = Astro.props;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
const origin = Astro.site?.origin ?? 'https://www.asbesta-schadstoffsanierung.de';
const ogImage = ogImageProp ?? `${origin}/og.png`;
const ogImageIsDefault = !ogImageProp;

// Self-gehostete @font-face mit font-display: optional (siehe Import-Kommentar). Per set:html in den
// <head> injiziert, damit die echten Build-URLs in src: stehen (CSS-Variablen sind in @font-face ungültig).
const LATIN =
  'U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD';
const LATIN_EXT =
  'U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF';
const fontFace = (weight: number, url: string, range: string): string =>
  `@font-face{font-family:'Barlow';font-style:normal;font-weight:${weight};font-display:optional;src:url(${url}) format('woff2');unicode-range:${range}}`;
const fontFaces = [
  fontFace(400, barlowBody, LATIN),
  fontFace(400, barlowExt400, LATIN_EXT),
  fontFace(600, barlowAccent, LATIN),
  fontFace(600, barlowExt600, LATIN_EXT),
  fontFace(900, barlowHeading, LATIN),
  fontFace(900, barlowExt900, LATIN_EXT),
].join('');
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preload" href={barlowBody} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={barlowHeading} as="font" type="font/woff2" crossorigin />
    <style set:html={fontFaces}></style>
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="robots"
      content={noindex
        ? 'noindex, follow'
        : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'}
    />
    <link rel="manifest" href="/site.webmanifest" />
    {/* GEO/KI: maschinenlesbare Endpunkte aus jeder Seite auffindbar machen */}
    <link
      rel="alternate"
      type="application/json"
      href={`${origin}/facts.json`}
      title="Asbesta – Fakten (JSON)"
    />
    <link
      rel="alternate"
      type="application/json"
      href={`${origin}/entities.json`}
      title="Asbesta – Entitäten (JSON)"
    />
    <link rel="alternate" type="text/plain" href={`${origin}/llms.txt`} title="llms.txt" />
    <link rel="alternate" type="text/plain" href={`${origin}/llms-full.txt`} title="llms-full.txt" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Asbesta Schadstoffsanierung" />
    <meta property="og:image" content={ogImage} />
    {ogImageIsDefault && <meta property="og:image:type" content="image/png" />}
    {ogImageIsDefault && <meta property="og:image:width" content="1200" />}
    {ogImageIsDefault && <meta property="og:image:height" content="630" />}
    <meta property="og:image:alt" content={title} />
    {
      ogType === 'article' && articlePublished && (
        <meta property="article:published_time" content={articlePublished} />
      )
    }
    {
      ogType === 'article' && articleModified && (
        <meta property="article:modified_time" content={articleModified} />
      )
    }
    {ogType === 'article' && articleAuthor && <meta property="article:author" content={articleAuthor} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />
    <meta name="theme-color" content="#141414" />
    {/* FOUC-Schutz: setzt `reveal-on` synchron VOR dem ersten Paint (winziges Inline-Snippet,
        kein parser-blockierender externer Request). Der IntersectionObserver wird per defer
        am Body-Ende nachgeladen. Bei prefers-reduced-motion/ohne JS bleibt alles sichtbar. */}
    <script is:inline>
      if (!window.matchMedia || !window.matchMedia('(prefers-reduced-motion: reduce)').matches)
        document.documentElement.classList.add('reveal-on');
    </script>
    <slot name="head" />
  </head>
  <body>
    <a
      href="#hauptinhalt"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-ink-900 focus:px-4 focus:py-2 focus:text-white"
      >Zum Inhalt springen</a
    >
    <Header />
    <main id="hauptinhalt" class="pb-16 md:pb-20">
      <slot />
    </main>
    <Footer />
    <MobileCallBar />
    <DesktopCtaBar />
    {
      CF_ANALYTICS_TOKEN && (
        <script
          defer
          is:inline
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${CF_ANALYTICS_TOKEN}"}`}
        ></script>
      )
    }
    {/* Scroll-Reveal-Observer: nicht kritisch -> defer (FOUC-Klasse setzt bereits das Head-Snippet) */}
    <script src="/scripts/reveal.js" defer is:inline></script>
    {/* Conversion-Tracking (Klick-Events) + Formular-Handler – extern, CSP-konform */}
    <script src="/scripts/conversions.js" defer is:inline></script>
    <script src="/scripts/anfrage-form.js" defer is:inline></script>
  </body>
</html>
