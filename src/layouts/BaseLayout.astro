---
import '@fontsource-variable/inter';
import '@fontsource-variable/archivo';
import '../styles/global.css';
import Header from '../components/patterns/Header.astro';
import Footer from '../components/patterns/Footer.astro';
import FloatingContact from '../components/patterns/FloatingContact.astro';
import MobileCallBar from '../components/patterns/MobileCallBar.astro';
import { CF_ANALYTICS_TOKEN } from '../lib/config';

interface Props {
  readonly title: string;
  readonly description: string;
  /** Index-Gate: true setzt <meta robots noindex,follow> (z. B. fuer noch duenne Seiten). */
  readonly noindex?: boolean;
}

const { title, description, noindex = false } = Astro.props;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
const origin = Astro.site?.origin ?? 'https://www.asbesta-schadstoffsanierung.de';
const ogImage = `${origin}/og.png`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="robots"
      content={noindex
        ? 'noindex, follow'
        : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'}
    />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Asbesta Schadstoffsanierung" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <meta name="theme-color" content="#141414" />
    <slot name="head" />
  </head>
  <body>
    <a
      href="#hauptinhalt"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-ink-900 focus:px-4 focus:py-2 focus:text-white"
      >Zum Inhalt springen</a
    >
    <Header />
    <main id="hauptinhalt" class="pb-16 md:pb-0">
      <slot />
    </main>
    <Footer />
    <MobileCallBar />
    <FloatingContact />
    {
      CF_ANALYTICS_TOKEN && (
        <script
          defer
          is:inline
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${CF_ANALYTICS_TOKEN}"}`}
        ></script>
      )
    }
  </body>
</html>
