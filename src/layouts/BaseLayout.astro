---
import '@fontsource-variable/inter';
import '@fontsource-variable/fraunces';
import '../styles/global.css';
import Header from '../components/patterns/Header.astro';
import Footer from '../components/patterns/Footer.astro';

interface Props {
  readonly title: string;
  readonly description: string;
}

const { title, description } = Astro.props;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="de_DE" />
    <meta name="theme-color" content="#0b2027" />
  </head>
  <body>
    <a
      href="#hauptinhalt"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-ink-900 focus:px-4 focus:py-2 focus:text-white"
      >Zum Inhalt springen</a
    >
    <Header />
    <main id="hauptinhalt" class="pb-16 md:pb-0">
      <slot />
    </main>
    <Footer />
  </body>
</html>
